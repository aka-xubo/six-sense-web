# Six Sense Web Backend Configuration

# Application
DEBUG=true

# Server
HOST=127.0.0.1
PORT=8000

# Database (optional, defaults to ~/.six-sense/web.db)
# DATA_DIR=/path/to/data
# DB_PATH=/path/to/web.db

# Chrome History (optional, defaults to macOS path)
# CHROME_HISTORY_PATH=/path/to/Chrome/History
